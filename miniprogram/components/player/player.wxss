.player-container {
  display: flex;
  justify-content: center;
}

.controls-row {
  display: flex;
  align-items: center;
  gap: 36rpx;
}

.ctrl-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.ctrl-btn:active {
  background: rgba(255, 255, 255, 0.12);
}

.icon {
  font-size: 30rpx;
  color: #888;
}

.ctrl-btn.primary {
  width: 104rpx;
  height: 104rpx;
  background: rgba(255, 215, 0, 0.12);
}

.ctrl-btn.primary:active {
  background: rgba(255, 215, 0, 0.2);
}

.primary-icon {
  font-size: 40rpx;
  color: #ffd700;
}

.speed-text {
  font-size: 24rpx;
  color: #ffd700;
  font-weight: 500;
}

.loop-icon {
  font-size: 26rpx;
}

.loop-active {
  background: rgba(255, 215, 0, 0.15);
}

.loop-active .loop-icon {
  color: #ffd700;
}
