.subtitle-scroll {
  width: 100%;
  max-height: 60vh;
}

.subtitle-block {
  padding: 24rpx 48rpx;
  opacity: 0.2;
  transition: opacity 0.35s ease;
}

.subtitle-block.done {
  opacity: 0.15;
}

.subtitle-block.active {
  opacity: 1;
}

.subtitle-main {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.subtitle-text {
  font-size: 34rpx;
  color: var(--color-text-primary);
  line-height: 1.7;
}

.subtitle-block.active .subtitle-text {
  font-size: 38rpx;
  color: var(--color-gold);
  font-weight: 500;
}

.subtitle-index {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.subtitle-block.active .subtitle-index {
  color: var(--color-gold);
}

.subtitle-translation {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, opacity 0.3s ease;
  opacity: 0;
}

.subtitle-translation.show {
  max-height: 80rpx;
  opacity: 1;
}

.subtitle-progress {
  margin-top: 16rpx;
  height: 3rpx;
  background: rgba(201, 168, 76, 0.15);
  border-radius: 2rpx;
  overflow: hidden;
}

.subtitle-progress-fill {
  height: 100%;
  background: var(--color-gold);
  border-radius: 2rpx;
  transition: width 0.1s linear;
}
