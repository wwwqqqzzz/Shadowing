/* ─── Base ────────────────────────────────────────────── */

page {
  background: #0f0f0f;
}

.container {
  min-height: 100vh;
  background: #0f0f0f;
}

/* ─── Filter top bar ─────────────────────────────────── */

.filter-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx 0;
}

.search-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #888;
  padding: 10rpx 20rpx;
  background: #1a1a1a;
  border-radius: 99rpx;
}

.search-icon {
  font-size: 24rpx;
}

.fav-toggle {
  font-size: 24rpx;
  color: #666;
  padding: 10rpx 24rpx;
  background: #1a1a1a;
  border-radius: 99rpx;
}

.fav-active {
  color: #e8a87c;
  background: rgba(232, 168, 124, 0.15);
}

/* ─── Search bar ──────────────────────────────────────── */

.search-bar {
  padding: 12rpx 32rpx 0;
}

.search-input {
  background: #1a1a1a;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #333;
}

/* ─── Filter section ─────────────────────────────────── */

.filter-section {
  padding: 12rpx 32rpx 0;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.filter-label {
  font-size: 24rpx;
  color: #888;
  min-width: 56rpx;
  flex-shrink: 0;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.filter-tag {
  font-size: 22rpx;
  color: #888;
  background: #2a2a2a;
  padding: 6rpx 20rpx;
  border-radius: 99rpx;
  white-space: nowrap;
}

.filter-tag.active {
  background: #a8e6cf;
  color: #0f0f0f;
  font-weight: 500;
}

/* ─── Results count ───────────────────────────────────── */

.results-count {
  padding: 12rpx 32rpx;
  font-size: 22rpx;
  color: #666;
}

/* ─── Card favorite button ────────────────────────────── */

.card-fav {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  z-index: 2;
  padding: 8rpx;
}

.card-fav-icon {
  font-size: 32rpx;
  color: #555;
}

.card-fav-icon.fav-filled {
  color: #e8a87c;
}

/* ─── Loading ─────────────────────────────────────────── */

.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
  gap: 24rpx;
}

.wait-dots {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wait-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #a8e6cf;
  opacity: 0.3;
  animation: dotPulse 1.5s ease-in-out infinite;
}

.wait-dot:nth-child(2) {
  animation-delay: 0.3s;
}

.wait-dot:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

/* ─── Empty state ─────────────────────────────────────── */

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #555;
}

/* ─── Card list ───────────────────────────────────────── */

.material-list {
  padding: 12rpx 0 24rpx;
}

.material-card {
  position: relative;
  margin: 12rpx 32rpx;
  background: #1a1a1a;
  border-radius: 24rpx;
  overflow: hidden;
}

.card-tap {
  opacity: 0.8;
}

/* ─── Cover ───────────────────────────────────────────── */

.card-cover {
  width: 100%;
  height: 320rpx;
  display: block;
}

.card-cover-placeholder {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, #2a2a2a 0%, #1a1a1a 100%);
}

/* ─── Card body ───────────────────────────────────────── */

.card-body {
  padding: 24rpx 28rpx 28rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
  line-height: 1.4;
}

/* ─── Tags row ────────────────────────────────────────── */

.card-tags {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tag-source {
  font-size: 22rpx;
  color: #888;
  background: #2a2a2a;
  padding: 4rpx 16rpx;
  border-radius: 99rpx;
}

.tag-accent {
  font-size: 22rpx;
  color: #999;
  background: #2a2a2a;
  padding: 4rpx 16rpx;
  border-radius: 99rpx;
}

.tag-level {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 99rpx;
  font-weight: 500;
}

.tag-beginner {
  background: rgba(168, 230, 207, 0.15);
  color: #a8e6cf;
}

.tag-intermediate {
  background: rgba(255, 217, 125, 0.15);
  color: #ffd97d;
}

.tag-advanced {
  background: rgba(255, 153, 153, 0.15);
  color: #ff9999;
}

.tag-duration {
  margin-left: auto;
  font-size: 22rpx;
  color: #666;
}
