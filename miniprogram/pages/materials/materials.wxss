/* ─── Base ────────────────────────────────────────────── */

page {
  background: var(--color-bg-base);
}

.container {
  min-height: 100vh;
  background: var(--color-bg-base);
}

/* ─── Filter top bar ─────────────────────────────────── */

.filter-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx 0;
}

.search-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  padding: 10rpx 20rpx;
  background: var(--color-bg-elevated);
  border-radius: 99rpx;
}

.filter-toggle-row {
  display: flex;
  gap: 12rpx;
}

.fav-toggle {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 10rpx 24rpx;
  background: var(--color-bg-elevated);
  border-radius: 99rpx;
}

.fav-active {
  color: var(--color-warning);
  background: rgba(201, 168, 76, 0.15);
}

.completed-toggle {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  padding: 10rpx 24rpx;
  background: var(--color-bg-elevated);
  border-radius: 99rpx;
}

.completed-active {
  color: var(--color-brand);
  background: rgba(125, 206, 160, 0.15);
}

/* ─── Search bar ──────────────────────────────────────── */

.search-bar {
  padding: 12rpx 32rpx 0;
}

.search-input {
  background: var(--color-bg-elevated);
  color: var(--color-text-primary);
  font-size: 28rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--color-border-strong);
}

/* ─── Filter section ─────────────────────────────────── */

.filter-section {
  padding: 12rpx 32rpx 0;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.filter-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  min-width: 56rpx;
  flex-shrink: 0;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.filter-tag {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background: var(--color-border-default);
  padding: 6rpx 20rpx;
  border-radius: 99rpx;
  white-space: nowrap;
}

.filter-tag.active {
  background: var(--color-brand);
  color: var(--color-bg-base);
  font-weight: 500;
}

/* ─── Results count ───────────────────────────────────── */

.results-count {
  padding: 12rpx 32rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* ─── Card favorite button ────────────────────────────── */

.card-fav {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 2;
  padding: 4rpx;
}

.card-fav-icon {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  opacity: 0.5;
}

.card-fav-icon.fav-filled {
  color: var(--color-warning);
  opacity: 1;
}

/* ─── Loading ─────────────────────────────────────────── */

.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
  gap: 24rpx;
}

.wait-dots {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wait-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-brand);
  opacity: 0.3;
  animation: dotPulse 1.5s ease-in-out infinite;
}

.wait-dot:nth-child(2) {
  animation-delay: 0.3s;
}

.wait-dot:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

/* ─── Empty state ─────────────────────────────────────── */

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

/* ─── Card list ───────────────────────────────────────── */

.material-list {
  padding: 12rpx 0 24rpx;
}

.material-card {
  position: relative;
  margin: 0 32rpx 12rpx;
  background: var(--color-bg-elevated);
  border-radius: 16rpx;
  padding: 28rpx;
  border-left: 4rpx solid var(--color-bg-elevated);
}

.material-card:active,
.card-tap {
  opacity: 0.8;
}

/* ─── Card body ───────────────────────────────────────── */

.card-body {
  padding: 24rpx 28rpx 28rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.4;
}

/* ─── Tags row ────────────────────────────────────────── */

.card-tags {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tag-source {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.tag-accent {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background: var(--color-border-default);
  padding: 4rpx 16rpx;
  border-radius: 99rpx;
}

.tag-level {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 99rpx;
  font-weight: 500;
}

.tag-beginner {
  background: rgba(125, 206, 160, 0.15);
  color: var(--color-brand);
}

.tag-intermediate {
  background: rgba(201, 168, 76, 0.15);
  color: var(--color-score-mid);
}

.tag-advanced {
  background: rgba(192, 97, 107, 0.15);
  color: var(--color-score-low);
}

.tag-duration {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* ─── Progress bar ────────────────────────────────────── */

.progress-text {
  font-size: 22rpx;
  color: var(--color-brand);
  font-weight: 500;
}

.progress-bar-wrap {
  height: 4rpx;
  background: var(--color-border-default);
  border-radius: 2rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: var(--color-brand);
  border-radius: 2rpx;
  transition: width 0.3s ease;
}

/* ─── Card level accent ─── */

.card-level-beginner {
  border-left-color: var(--color-brand);
}

.card-level-intermediate {
  border-left-color: var(--color-score-mid);
}

.card-level-advanced {
  border-left-color: var(--color-score-low);
}
