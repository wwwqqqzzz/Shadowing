/* ─── Base ────────────────────────────────────────────── */

page {
  background: #0f0f0f;
}

.container {
  min-height: 100vh;
  background: #0f0f0f;
}

/* ─── Loading ─────────────────────────────────────────── */

.loading-area {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.wait-dots {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wait-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #a8e6cf;
  opacity: 0.3;
  animation: dotPulse 1.5s ease-in-out infinite;
}

.wait-dot:nth-child(2) {
  animation-delay: 0.3s;
}

.wait-dot:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

/* ─── Stats cards ─────────────────────────────────────── */

.stats-row {
  display: flex;
  gap: 10px;
  padding: 32rpx 32rpx 0;
}

.stats-card {
  flex: 1;
  background: #1a1a1a;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stats-number {
  font-size: 64rpx;
  font-weight: 600;
  color: #ffffff;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
}

.streak-card {
  cursor: pointer;
}

.streak-hint {
  font-size: 18rpx;
  color: #e8a87c;
  margin-top: 2rpx;
}

/* ─── Streak detail ──────────────────────────────────── */

.extra-row {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx;
  margin-top: 16rpx;
}

.extra-item {
  flex: 1;
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.extra-label {
  font-size: 22rpx;
  color: #555;
}

.extra-value {
  font-size: 26rpx;
  color: #ccc;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ─── 7-day heatmap chart ─────────────────────────────── */

.weekly-chart {
  margin: 24rpx 32rpx 0;
  background: #1a1a1a;
  border-radius: 20rpx;
  padding: 28rpx 20rpx 16rpx;
}

.weekly-bars {
  display: flex;
  align-items: flex-end;
  height: 240rpx;
  gap: 8rpx;
}

.weekly-bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  position: relative;
}

.weekly-bar-track {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.weekly-bar-fill {
  width: 70%;
  min-height: 6rpx;
  border-radius: 6rpx 6rpx 0 0;
  background: #222;
  transition: height 0.3s ease;
}

.weekly-bar-fill.active {
  background: #a8e6cf;
}

.weekly-bar-label {
  font-size: 20rpx;
  color: #444;
  margin-top: 10rpx;
}

.weekly-bar-count {
  font-size: 18rpx;
  color: #a8e6cf;
  position: absolute;
  top: 0;
  text-align: center;
  width: 100%;
}

.streak-detail {
  font-size: 12px;
  color: #555;
  text-align: center;
  margin-top: 6px;
  margin-bottom: 16px;
  padding: 0 32rpx;
}

/* ─── Calendar ───────────────────────────────────────── */

.calendar-wrap {
  background: #141414;
  border-radius: 16rpx;
  padding: 24rpx 20rpx 20rpx;
  margin: 0 32rpx 20rpx;
  overflow: hidden;
}

@keyframes calZoomIn {
  from { opacity: 0; transform: scale(0.7); }
  to   { opacity: 1; transform: scale(1); }
}

/* Header */
.cal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}
.cal-back {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}
.cal-back-icon {
  font-size: 32rpx;
  color: #a8e6cf;
}
.cal-back-text {
  font-size: 24rpx;
  color: #a8e6cf;
}
.cal-backPlaceholder {
  width: 80rpx;
}
.cal-title {
  font-size: 28rpx;
  color: #ccc;
  font-weight: 600;
}
.cal-headerSpacer {
  width: 80rpx;
}

/* Level 1: Year grid */
.year-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}
.year-month-cell {
  background: #1e1e1e;
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.year-month-cell.current {
  border: 2rpx solid #a8e6cf;
}
.year-month-cell.has-data {
  background: #222;
}
.ym-label {
  font-size: 24rpx;
  color: #aaa;
}
.ym-count {
  font-size: 20rpx;
  color: #4ade80;
}

/* Level 2: Month view */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}
.month-nav-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #888;
  border-radius: 50%;
}
.month-nav-btn:active {
  background: #222;
}
.month-nav-label {
  font-size: 28rpx;
  color: #ccc;
  font-weight: 600;
}
.month-weekdays {
  display: flex;
  margin-bottom: 8rpx;
}
.mw-cell {
  width: calc(100% / 7);
  text-align: center;
  font-size: 20rpx;
  color: #3a3a3a;
  padding: 8rpx 0;
}
.month-grid {
  display: flex;
  flex-wrap: wrap;
}
.day-cell {
  width: calc(100% / 7);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  font-size: 22rpx;
  color: #4a4a4a;
  position: relative;
}
.day-cell.done {
  color: #ccc;
}
.day-cell.done::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #4ade80;
}
.day-cell.today {
  color: #a8e6cf;
  font-weight: 700;
}
.day-cell.today::before {
  content: '';
  position: absolute;
  inset: 6rpx;
  border: 2rpx solid #a8e6cf;
  border-radius: 50%;
}
.day-cell.future {
  color: #222;
}
.day-cell.empty {
  visibility: hidden;
}

/* Level 3: Day view */
.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}
.day-date {
  font-size: 28rpx;
  color: #ddd;
  font-weight: 600;
}
.day-count {
  font-size: 22rpx;
  color: #4ade80;
}
.day-empty {
  padding: 60rpx 0;
  text-align: center;
}
.day-empty-text {
  font-size: 24rpx;
  color: #444;
}
.day-records {
  max-height: 400rpx;
  overflow-y: auto;
}
.day-record {
  padding: 16rpx 12rpx;
  border-bottom: 2rpx solid #1e1e1e;
}
.day-record-text {
  font-size: 24rpx;
  color: #bbb;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.day-record-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 6rpx;
}
.day-record-dur {
  font-size: 20rpx;
  color: #555;
}
.day-record-score {
  font-size: 20rpx;
  color: #4ade80;
}

/* ─── Settings entry ────────────────────────────────────── */

.settings-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #1e1e1e;
}

.settings-label {
  font-size: 28rpx;
  color: #888;
}

.settings-arrow {
  font-size: 32rpx;
  color: #555;
}

/* ─── Wrong book entry ────────────────────────────────────── */

.wrong-book-row { flex-wrap: nowrap; }
.wrong-book-left { display: flex; align-items: center; gap: 12rpx; }
.wrong-book-right { display: flex; align-items: center; gap: 16rpx; }
.wrong-hint { font-size: 22rpx; color: #e8a87c; }
.wrong-badge {
  background: #a8e6cf;
  color: #0f0f0f;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* ─── Section title ───────────────────────────────────── */

.section-title {
  font-size: 26rpx;
  color: #666;
  padding: 48rpx 32rpx 20rpx;
}

/* ─── Record list ─────────────────────────────────────── */

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #1e1e1e;
}

.item-tap {
  opacity: 0.7;
}

.record-left {
  flex: 1;
  min-width: 0;
  margin-right: 24rpx;
}

.record-material-title {
  display: block;
  font-size: 28rpx;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-text {
  display: block;
  font-size: 24rpx;
  color: #555;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.record-duration {
  font-size: 26rpx;
  color: #a8e6cf;
}

.record-time {
  font-size: 22rpx;
  color: #444;
  margin-top: 4rpx;
}

/* ─── Empty state ─────────────────────────────────────── */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  gap: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #555;
  text-align: center;
  padding: 0 60rpx;
  line-height: 1.6;
}

.empty-btn {
  padding: 20rpx 48rpx;
  border-radius: 99rpx;
  background: #a8e6cf;
  font-size: 28rpx;
  color: #0f0f0f;
  font-weight: 500;
}

.empty-btn:active {
  opacity: 0.7;
}