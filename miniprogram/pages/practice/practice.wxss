/* ─── Mode modal ──────────────────────────────────────── */

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-box {
  width: 85%;
  background: var(--color-bg-elevated);
  border-radius: 32rpx;
  padding: 48rpx 36rpx;
}

.modal-title {
  display: block;
  font-size: 32rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  text-align: center;
}

.modal-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  text-align: center;
  margin-top: 8rpx;
  margin-bottom: 40rpx;
}

.modal-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.modal-option {
  background: var(--color-border-default);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
}

.modal-option-tap {
  background: var(--color-text-tertiary);
}

.modal-option-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.modal-option-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-brand-dim);
  color: var(--color-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.modal-option-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.modal-option-name {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.modal-option-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

/* ─── Base ────────────────────────────────────────────── */

page {
  background: var(--color-bg-base);
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg-base);
  position: relative;
}

/* ─── Finished overlay ───────────────────────────────── */

.finished-wrap {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-base);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 48rpx 64rpx;
  z-index: 100;
}

.finished-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-brand);
  margin-bottom: 24rpx;
}

.finished-material {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 32rpx;
}

.finished-stats {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 80rpx;
}

.finished-stat-main {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.finished-stat-score {
  font-size: 26rpx;
  color: var(--color-brand);
}

.finished-buttons {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  width: 100%;
}

.btn-restart {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-brand-dim);
  color: var(--color-brand);
  border: 1rpx solid var(--color-brand);
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
}

.btn-back {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-elevated);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border-default);
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
}

.btn-tap {
  opacity: 0.7;
}

/* ─── Top bar ─────────────────────────────────────────── */

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 40rpx;
  flex-shrink: 0;
}

.title-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.progress-label {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

/* ─── Subtitle area ───────────────────────────────────── */

.subtitle-wrapper {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.subtitle-area {
  width: 100%;
  height: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.subtitle-item {
  padding: 16rpx 0;
}

.subtitle-text {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.7;
  opacity: 0.35;
  transition: opacity 0.3s ease, font-size 0.3s ease;
  word-break: break-word;
}

.subtitle-item.active .subtitle-text {
  font-size: 36rpx;
  opacity: 1;
  color: var(--color-brand);
}

.subtitle-translation {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  line-height: 1.5;
}

/* ─── Status area ─────────────────────────────────────── */

.status-area {
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60rpx;
  padding: 0 40rpx 16rpx;
}

.wait-dots {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wait-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-brand);
  opacity: 0.3;
  animation: dotPulse 1.5s ease-in-out infinite;
}

.wait-dot:nth-child(2) {
  animation-delay: 0.3s;
}

.wait-dot:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

.finished-text {
  font-size: 28rpx;
  color: var(--color-brand);
  letter-spacing: 4rpx;
}

/* ─── Recorder row ─────────────────────────────────────── */

.waiting-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.recorder-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.rec-btn {
  min-width: 120rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  background: var(--color-bg-elevated);
  border: 2rpx solid var(--color-border-strong);
  padding: 0 28rpx;
}

.rec-btn:active {
  opacity: 0.7;
}

.rec-btn.recording {
  border-color: var(--color-recording);
  background: rgba(192, 97, 107, 0.08);
}

.rec-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.rec-btn.recording .rec-label {
  color: var(--color-recording);
}

.skip-label {
  color: var(--color-text-tertiary);
}

.playback-icon-label {
  color: var(--color-brand);
}

.recording-label {
  font-size: 26rpx;
  color: var(--color-recording);
  letter-spacing: 2rpx;
}

@keyframes recPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ─── Controls ────────────────────────────────────────── */

.controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  padding: 16rpx 40rpx 60rpx;
  flex-shrink: 0;
}

.ctrl-btn {
  min-width: 80rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 36rpx;
  background: var(--color-bg-elevated);
}

.ctrl-btn:active {
  background: rgba(255, 255, 255, 0.1);
}

.ctrl-btn.play-btn {
  min-width: 160rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: var(--color-brand);
}

.ctrl-btn.play-btn:active {
  opacity: 0.85;
}

.ctrl-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.play-text {
  font-size: 28rpx;
  color: var(--color-bg-base);
  font-weight: 600;
}

.speed-label {
  font-size: 24rpx;
  color: var(--color-brand);
  font-weight: 500;
}

.loop-on {
  background: var(--color-brand-dim);
}

.loop-on .ctrl-text {
  color: var(--color-brand);
}

/* ─── Feedback ────────────────────────────────────────── */

.feedback-area {
  background: var(--color-bg-elevated);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  margin: 0 32rpx 24rpx;
  flex-shrink: 0;
}

.feedback-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.feedback-score {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.score-high {
  color: var(--color-brand);
}

.score-mid {
  color: var(--color-score-mid);
}

.score-low {
  color: var(--color-score-low);
}

.feedback-words {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.missing-tag {
  background: var(--color-error);
  color: var(--color-score-low);
  font-size: 22rpx;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  line-height: 1.5;
}

.feedback-texts {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 20rpx;
}

.feedback-recognized {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.feedback-original {
  font-size: 24rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}
