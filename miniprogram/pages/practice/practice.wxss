/* ─── Base ────────────────────────────────────────────── */

page {
  background: #0f0f0f;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0f0f0f;
}

/* ─── Top bar ─────────────────────────────────────────── */

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 40rpx;
  flex-shrink: 0;
}

.title-text {
  font-size: 26rpx;
  color: #666;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.progress-label {
  font-size: 26rpx;
  color: #555;
}

/* ─── Subtitle area ───────────────────────────────────── */

.subtitle-wrapper {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.subtitle-area {
  width: 100%;
  height: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.subtitle-item {
  padding: 16rpx 0;
}

.subtitle-text {
  display: block;
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1.7;
  opacity: 0.35;
  transition: opacity 0.3s ease, font-size 0.3s ease;
  word-break: break-word;
}

.subtitle-item.active .subtitle-text {
  font-size: 36rpx;
  opacity: 1;
  color: #a8e6cf;
}

.subtitle-translation {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.5;
}

/* ─── Status area ─────────────────────────────────────── */

.status-area {
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60rpx;
  padding: 0 40rpx 16rpx;
}

.wait-dots {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wait-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #a8e6cf;
  opacity: 0.3;
  animation: dotPulse 1.5s ease-in-out infinite;
}

.wait-dot:nth-child(2) {
  animation-delay: 0.3s;
}

.wait-dot:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

.finished-text {
  font-size: 28rpx;
  color: #a8e6cf;
  letter-spacing: 4rpx;
}

/* ─── Recorder row ─────────────────────────────────────── */

.waiting-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.recorder-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.rec-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #1a1a1a;
  border: 2rpx solid #333;
}

.rec-btn:active {
  opacity: 0.7;
}

.rec-btn.recording {
  border-color: #ff4d4d;
}

.rec-icon {
  font-size: 30rpx;
  color: #888;
}

.rec-btn.recording .rec-icon {
  color: #ff4d4d;
  animation: recPulse 0.8s ease-in-out infinite;
}

.playback-icon {
  color: #a8e6cf;
}

.skip-icon {
  font-size: 24rpx;
  color: #888;
}

.recording-label {
  font-size: 26rpx;
  color: #ff4d4d;
  letter-spacing: 2rpx;
}

@keyframes recPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ─── Controls ────────────────────────────────────────── */

.controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  padding: 16rpx 40rpx 60rpx;
  flex-shrink: 0;
}

.ctrl-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.ctrl-btn:active {
  background: rgba(255, 255, 255, 0.12);
}

.ctrl-btn.play-btn {
  width: 104rpx;
  height: 104rpx;
  background: rgba(168, 230, 207, 0.1);
}

.ctrl-btn.play-btn:active {
  background: rgba(168, 230, 207, 0.2);
}

.ctrl-icon {
  font-size: 30rpx;
  color: #888;
}

.play-icon {
  font-size: 38rpx;
  color: #a8e6cf;
}

.speed-label {
  font-size: 24rpx;
  color: #a8e6cf;
  font-weight: 500;
}

.loop-on {
  background: rgba(168, 230, 207, 0.12);
}

.loop-on .ctrl-icon {
  color: #a8e6cf;
}

/* ─── Feedback ────────────────────────────────────────── */

.feedback-area {
  background: #1a1a1a;
  border-radius: 12px;
  padding: 14px 16px;
  margin: 0 40rpx 12px;
  flex-shrink: 0;
}

.feedback-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.feedback-score {
  font-size: 36px;
  font-weight: 700;
  line-height: 1;
}

.score-high {
  color: #a8e6cf;
}

.score-mid {
  color: #ffd97d;
}

.score-low {
  color: #ff9999;
}

.feedback-words {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.missing-tag {
  background: #3a1a1a;
  color: #ff9999;
  font-size: 22rpx;
  border-radius: 4px;
  padding: 2px 6px;
  line-height: 1.5;
}

.feedback-texts {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-top: 10px;
}

.feedback-recognized {
  font-size: 12px;
  color: #888;
  line-height: 1.6;
}

.feedback-original {
  font-size: 12px;
  color: #ddd;
  line-height: 1.6;
}
