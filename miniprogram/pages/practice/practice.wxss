/* ─── Mode modal ──────────────────────────────────────── */

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-box {
  width: 85%;
  background: var(--color-bg-elevated);
  border-radius: 32rpx;
  padding: 48rpx 36rpx;
}

.modal-title {
  display: block;
  font-size: 32rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  text-align: center;
}

.modal-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  text-align: center;
  margin-top: 8rpx;
  margin-bottom: 40rpx;
}

.modal-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.modal-option {
  background: var(--color-border-default);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
}

.modal-option-tap {
  background: var(--color-text-tertiary);
}

.modal-option-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.modal-option-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-brand-dim);
  color: var(--color-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.modal-option-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.modal-option-name {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.modal-option-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

/* ─── Base ────────────────────────────────────────────── */

page {
  background: var(--color-bg-base);
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg-base);
  position: relative;
}

/* ─── Finished overlay ───────────────────────────────── */

.finished-wrap {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-base);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 48rpx 64rpx;
  z-index: 100;
}

.finished-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-brand);
  margin-bottom: 24rpx;
}

.finished-material {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 32rpx;
}

.finished-stats {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 80rpx;
}

.finished-stat-main {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.finished-stat-score {
  font-size: 26rpx;
  color: var(--color-brand);
}

.finished-buttons {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  width: 100%;
}

.btn-restart {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-brand-dim);
  color: var(--color-brand);
  border: 1rpx solid var(--color-brand);
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
}

.btn-back {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-elevated);
  color: var(--color-text-secondary);
  border: 1rpx solid var(--color-border-default);
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
}

.btn-tap {
  opacity: 0.7;
}

/* ─── Top bar ─────────────────────────────────────────── */

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 40rpx;
  flex-shrink: 0;
}

.title-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.progress-label {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.top-bar-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* ─── Echo toggle (shadow mode) ─────────────────────────── */

.echo-toggle {
  display: flex;
  align-items: center;
  gap: 10rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: var(--color-bg-elevated);
  border: 1rpx solid var(--color-border-default);
  transition: background-color 0.2s ease, border-color 0.2s ease;
}

.echo-toggle.echo-on {
  background: var(--color-brand-dim);
  border-color: var(--color-brand);
}

.echo-toggle-tap {
  opacity: 0.7;
}

.echo-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-text-tertiary);
  transition: background-color 0.2s ease;
}

.echo-dot.echo-dot-on {
  background: var(--color-brand);
  box-shadow: 0 0 8rpx rgba(125, 206, 160, 0.6);
}

.echo-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.echo-toggle.echo-on .echo-label {
  color: var(--color-brand);
}

/* ─── Subtitle area — context window ───────────────────── */

.subtitle-wrapper {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.subtitle-area {
  width: 100%;
  height: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.subtitle-item {
  padding: var(--space-2) 0;
}

.subtitle-text {
  display: block;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  line-height: var(--line-height-normal);
  word-break: break-word;
  transition: opacity 0.3s ease, font-size 0.3s ease, color 0.3s ease;
}

/* Context window: current sentence — brand color, large, full opacity */
.subtitle-item.active .subtitle-text {
  font-size: var(--font-size-lg);
  opacity: 1;
  color: var(--color-brand);
  line-height: var(--line-height-loose);
}

.subtitle-translation {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  line-height: var(--line-height-normal);
}

/* Context window: ±1 sentence — readable, slight dim */
.subtitle-item.nearby .subtitle-text {
  opacity: 0.55;
  color: var(--color-text-primary);
  font-size: var(--font-size-base);
}

/* Context window: distant sentences — reduced but readable */
.subtitle-item.dimmed .subtitle-text {
  opacity: 0.25;
  font-size: var(--font-size-sm);
}

/* ─── Word-level rendering (active sentence) ──────────── */

.word-row {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx 12rpx;
}

.word-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 2rpx 4rpx;
  border-radius: 4rpx;
  transition: background-color 0.15s ease, transform 0.15s ease;
}

.word-text {
  font-size: var(--font-size-lg);
  color: var(--color-brand);
  line-height: var(--line-height-loose);
}

.word-highlight .word-text {
  background-color: rgba(168, 230, 207, 0.25);
  transform: scale(1.05);
  border-radius: 4rpx;
}

.word-pronouncing {
  background-color: rgba(168, 230, 207, 0.15);
}

.word-pronouncing .word-text {
  border-bottom: 3rpx solid var(--color-brand);
}

.word-ipa {
  font-size: 18rpx;
  color: var(--color-text-tertiary);
  line-height: 1;
  margin-top: 2rpx;
}

/* ─── Status area ─────────────────────────────────────── */

.status-area {
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60rpx;
  padding: 0 40rpx 16rpx;
}

.wait-dots {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wait-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-brand);
  opacity: 0.3;
  animation: dotPulse 1.5s ease-in-out infinite;
}

.wait-dot:nth-child(2) {
  animation-delay: 0.3s;
}

.wait-dot:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

.finished-text {
  font-size: 28rpx;
  color: var(--color-brand);
  letter-spacing: 4rpx;
}

/* ─── Recorder row ─────────────────────────────────────── */

.waiting-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.recorder-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.rec-btn {
  min-width: 120rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  background: var(--color-bg-elevated);
  border: 2rpx solid var(--color-border-strong);
  padding: 0 28rpx;
}

.rec-btn:active {
  opacity: 0.7;
}

.rec-btn.recording {
  border-color: var(--color-recording);
  background: rgba(192, 97, 107, 0.08);
}

.rec-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.rec-btn.recording .rec-label {
  color: var(--color-recording);
}

.skip-label {
  color: var(--color-text-tertiary);
}

.playback-icon-label {
  color: var(--color-brand);
}

.recording-label {
  font-size: 26rpx;
  color: var(--color-recording);
  letter-spacing: 2rpx;
}

@keyframes recPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ─── Controls ────────────────────────────────────────── */

.controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-3) var(--space-4) 60rpx;
  background: var(--color-bg-surface);
  border-top: 1rpx solid var(--color-border-subtle);
  flex-shrink: 0;
}

.ctrl-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--color-bg-elevated);
}

.ctrl-btn:active {
  background: rgba(255, 255, 255, 0.1);
}

.ctrl-btn-primary {
  width: 100rpx;
  height: 100rpx;
  background: var(--color-brand-dim);
  color: var(--color-brand);
  border: 1rpx solid rgba(125, 206, 160, 0.2);
  border-radius: var(--radius-full);
}

.ctrl-btn-primary:active {
  opacity: 0.85;
}

.ctrl-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.play-text {
  font-size: var(--font-size-base);
  color: var(--color-bg-base);
  font-weight: var(--font-weight-semibold);
}

.speed-label {
  font-size: var(--font-size-sm);
  color: var(--color-brand);
  font-weight: var(--font-weight-semibold);
}

.ctrl-btn.active {
  color: var(--color-brand);
  background: var(--color-brand-dim);
}

/* ─── Feedback ────────────────────────────────────────── */

.feedback-wrap {
  background: var(--color-bg-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-border-subtle);
  padding: var(--space-3) var(--space-4);
  margin: 0 var(--space-4) var(--space-3);
  flex-shrink: 0;
}

.feedback-score-row {
  display: flex;
  align-items: baseline;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.feedback-failed-row {
  padding: var(--space-2) 0;
  margin-bottom: var(--space-3);
  border-left: 4rpx solid var(--color-score-low);
  padding-left: var(--space-3);
}

.feedback-failed-text {
  font-size: var(--font-size-base);
  color: var(--color-score-low);
  font-weight: var(--font-weight-medium);
}

.feedback-score-num {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-semibold);
  line-height: 1;
}

.feedback-score-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.feedback-missing-row {
  margin-bottom: var(--space-2);
}

.feedback-missing-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-bottom: 6rpx;
  display: block;
}

.feedback-missing-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.feedback-missing-tag {
  font-size: var(--font-size-xs);
  color: var(--color-score-low);
  background: rgba(192, 97, 107, 0.12);
  border: 1rpx solid rgba(192, 97, 107, 0.25);
  border-radius: var(--radius-sm);
  padding: 4rpx var(--space-2);
}

.feedback-text-row {
  margin-top: var(--space-2);
  padding-top: var(--space-2);
  border-top: 1rpx solid var(--color-border-subtle);
}

.feedback-text-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  display: block;
  margin-bottom: 4rpx;
}

.feedback-text-content {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);
  display: block;
}

.feedback-text-original {
  color: var(--color-text-primary);
}

/* ─── Legacy feedback classes (kept for backward compat) ─── */

.feedback-area {
  background: var(--color-bg-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-border-subtle);
  padding: var(--space-3) var(--space-4);
  margin: 0 var(--space-4) var(--space-3);
  flex-shrink: 0;
}

.feedback-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.feedback-score {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-semibold);
  line-height: 1;
}

.score-high {
  color: var(--color-brand);
}

.score-mid {
  color: var(--color-score-mid);
}

.score-low {
  color: var(--color-score-low);
}

.feedback-words {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
}

.missing-tag {
  background: rgba(192, 97, 107, 0.12);
  color: var(--color-score-low);
  font-size: var(--font-size-xs);
  border: 1rpx solid rgba(192, 97, 107, 0.25);
  border-radius: var(--radius-sm);
  padding: 4rpx 12rpx;
  line-height: var(--line-height-normal);
}

.feedback-texts {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: var(--space-2);
  padding-top: var(--space-2);
  border-top: 1rpx solid var(--color-border-subtle);
}

.feedback-recognized {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);
}

.feedback-original {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  line-height: var(--line-height-normal);
}

/* ─── Word-level feedback ────────────────────────────────── */

.feedback-words {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 16rpx;
  margin: var(--space-2) 0;
}

.feedback-word-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 48rpx;
}

.feedback-word {
  font-size: var(--font-size-base);
  line-height: 1.3;
  padding: 4rpx 8rpx;
  border-radius: var(--radius-sm);
}

.feedback-word-correct {
  color: var(--color-brand);
}

.feedback-word-missing {
  color: var(--color-score-low);
  background: rgba(192, 97, 107, 0.08);
  text-decoration: line-through;
  text-decoration-color: rgba(192, 97, 107, 0.5);
}

.feedback-word-mispronounced {
  color: var(--color-score-mid);
  background: rgba(212, 160, 67, 0.08);
  border-bottom: 2rpx solid var(--color-score-mid);
}

.feedback-word-extra {
  color: var(--color-text-tertiary);
  font-style: italic;
}

.feedback-word-hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  line-height: 1;
}

/* ─── Shadow mode finished page ─────────────────────────── */

.finished-stat-shadow {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.finished-shadow-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  margin-bottom: 40rpx;
}

.btn-shadow-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-brand);
  color: var(--color-text-inverse);
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 0;
  width: 100%;
}

.btn-shadow-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-elevated);
  color: var(--color-text-primary);
  border: 1rpx solid var(--color-border-default);
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 22rpx 0;
  width: 100%;
}

.btn-shadow-text {
  font-size: inherit;
  color: inherit;
}

.finished-shadow-progress {
  margin-bottom: 24rpx;
}

.finished-shadow-progress-text {
  font-size: 24rpx;
  color: var(--color-brand);
  letter-spacing: 2rpx;
}

/* ─── Recording pulse (shadow mode indicator) ──────────── */

.recording-label {
  font-size: 26rpx;
  color: var(--color-recording);
  letter-spacing: 2rpx;
  animation: recPulse 1.4s ease-in-out infinite;
}

/* ─── Shadow mode float toggle (bottom-right) ─────────── */

.shadow-float {
  position: fixed;
  bottom: 180rpx;
  right: 32rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-bg-elevated);
  border: 2rpx solid var(--color-border-default);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 50;
  transition: background-color 0.2s ease, border-color 0.2s ease;
}

.shadow-float.shadow-float-on {
  background: var(--color-brand-dim);
  border-color: var(--color-brand);
}

.shadow-float-tap {
  opacity: 0.7;
}

.shadow-float-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-tertiary);
  transition: color 0.2s ease;
}

.shadow-float-on .shadow-float-text {
  color: var(--color-brand);
}
