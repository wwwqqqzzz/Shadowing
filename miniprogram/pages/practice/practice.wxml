<view class="container">
  <!-- Mode selection modal -->
  <view class="modal-mask" wx:if="{{showModeModal}}">
    <view class="modal-box">
      <text class="modal-title">选择你的跟读方式</text>
      <text class="modal-subtitle">可在「我的」→「设置」中修改</text>
      <view class="modal-options">
        <view
          wx:for="{{modeModes}}"
          wx:key="key"
          class="modal-option"
          data-mode="{{item.key}}"
          bindtap="onSelectMode"
          hover-class="modal-option-tap"
        >
          <view class="modal-option-left">
            <view class="modal-option-badge">{{item.name[0]}}</view>
            <view class="modal-option-info">
              <text class="modal-option-name">{{item.name}}</text>
              <text class="modal-option-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Finished overlay -->
  <view wx:if="{{status === 'finished' && finishedData}}" class="finished-wrap">
    <text class="finished-title">练习完成</text>
    <text class="finished-material">{{finishedData.title}}</text>
    <view class="finished-stats">
      <text class="finished-stat-main">{{finishedData.total}} 句  ·  {{finishedData.durationText}}</text>
      <text wx:if="{{finishedData.showScore}}" class="finished-stat-score">平均 {{finishedData.avgScore}} 分</text>
      <text wx:if="{{finishedData.shadowMode}}" class="finished-stat-shadow">跟读 {{finishedData.shadowWithAudio}} / {{finishedData.shadowTotal}} 句</text>
    </view>
    <view wx:if="{{finishedData.shadowMode}}" class="finished-shadow-buttons">
      <view class="btn-shadow-primary" bindtap="_playCompleteShadow" hover-class="btn-tap" wx:if="{{!shadowCompletePlaying}}">
        <text class="btn-shadow-text">听我的跟读</text>
      </view>
      <view class="btn-shadow-primary" bindtap="onStopCompletePlayback" hover-class="btn-tap" wx:if="{{shadowCompletePlaying}}">
        <text class="btn-shadow-text">停止回放</text>
      </view>
      <view class="btn-shadow-secondary" bindtap="_playCompleteOriginal" hover-class="btn-tap" wx:if="{{!shadowCompletePlaying}}">
        <text class="btn-shadow-text">再听原音</text>
      </view>
    </view>
    <view wx:if="{{shadowCompletePlaying && shadowCompleteSource === 'self'}}" class="finished-shadow-progress">
      <text class="finished-shadow-progress-text">回放中 {{shadowPlayIndex + 1}} / {{finishedData.shadowWithAudio}}</text>
    </view>
    <view class="finished-buttons">
      <view class="btn-restart" bindtap="onTapRestart" hover-class="btn-tap">重新练</view>
      <view class="btn-back" bindtap="onTapBack" hover-class="btn-tap">返回</view>
    </view>
  </view>

  <!-- Top bar: title + progress + echo toggle (shadow mode) -->
  <view class="top-bar" wx:if="{{status !== 'finished'}}">
    <text class="title-text">{{material.title}}</text>
    <view class="top-bar-right">
      <view wx:if="{{practiceMode === 'shadow'}}" class="echo-toggle {{echoEnabled ? 'echo-on' : ''}}" bindtap="onToggleEcho" hover-class="echo-toggle-tap">
        <view class="echo-dot {{echoEnabled ? 'echo-dot-on' : ''}}"></view>
        <text class="echo-label">回声</text>
      </view>
      <text class="progress-label">{{currentIndex + 1}} / {{sentences.length}}</text>
    </view>
  </view>

  <!-- Subtitles — context window: active/nearby/dimmed -->
  <view class="subtitle-wrapper" wx:if="{{status !== 'finished'}}">
    <scroll-view class="subtitle-area" scroll-y scroll-into-view="s-{{currentIndex}}" scroll-with-animation bindtap="onTapSubtitleBg">
      <view
        wx:for="{{sentences}}"
        wx:key="id"
        id="s-{{index}}"
        class="subtitle-item {{index === currentIndex ? 'active' : (index === currentIndex - 1 || index === currentIndex + 1) ? 'nearby' : 'dimmed'}}"
        data-index="{{index}}"
        catchtap="onTapSentence"
      >
        <!-- Active sentence: word-level rendering with highlight + longpress -->
        <view wx:if="{{index === currentIndex && currentWords.length > 0}}" class="word-row">
          <view
            wx:for="{{currentWords}}"
            wx:for-item="cw"
            wx:key="index"
            class="word-wrap {{cw.index === currentWordIndex ? 'word-highlight' : ''}} {{pronouncingWord === cw.word ? 'word-pronouncing' : ''}}"
            data-word="{{cw.word}}"
            bindlongpress="onLongPressWord"
          >
            <text class="word-text">{{cw.word}}</text>
            <text wx:if="{{pronouncingWord === cw.word && pronouncingIpa}}" class="word-ipa">{{pronouncingIpa}}</text>
          </view>
        </view>
        <!-- Non-active sentences: plain text -->
        <text wx:else class="subtitle-text">{{item.text}}</text>
        <!-- Translation always visible for active sentence -->
        <text class="subtitle-translation" wx:if="{{index === currentIndex && item.translation}}">{{item.translation}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- Wait indicator -->
  <view class="status-area" wx:if="{{status !== 'finished'}}">
    <view wx:if="{{status === 'waiting' || recording || (practiceMode === 'shadow' && playingBack && shadowCompleteSource !== 'original')}}" class="waiting-container">
      <view class="wait-dots" wx:if="{{!recording && !(practiceMode === 'shadow' && playingBack)}}">
        <view class="wait-dot"></view>
        <view class="wait-dot"></view>
        <view class="wait-dot"></view>
      </view>
      <text class="recording-label" wx:if="{{recording}}">跟读中…</text>
      <text class="recording-label" wx:if="{{!recording && practiceMode === 'shadow' && playingBack}}">回放中…</text>
      <view class="recorder-row">
        <view class="rec-btn {{recording ? 'recording' : ''}}" bindtap="onToggleRecord" wx:if="{{practiceMode !== 'shadow'}}">
          <text class="rec-label">{{recording ? '停止' : '录音'}}</text>
        </view>
        <view class="rec-btn" wx:if="{{recordPath && !recording && practiceMode !== 'shadow'}}" bindtap="onPlayback">
          <text class="rec-label">回放</text>
        </view>
        <view class="rec-btn" wx:if="{{practiceMode === 'shadow' && playingBack && !shadowCompletePlaying}}" bindtap="onSkipShadowPlayback">
          <text class="rec-label skip-label">跳过回放</text>
        </view>
        <view class="rec-btn" bindtap="onSkipNext">
          <text class="rec-label skip-label">下一句</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Feedback -->
  <view class="feedback-area" wx:if="{{showFeedback && feedback && status !== 'finished'}}">
    <view wx:if="{{feedback.evalFailed}}" class="feedback-failed-row">
      <text class="feedback-failed-text">评估失败，无法给出评分</text>
    </view>
    <view wx:else class="feedback-score-row">
      <text class="feedback-score-num {{feedback.score >= 80 ? 'score-high' : (feedback.score >= 60 ? 'score-mid' : 'score-low')}}">{{feedback.score}}</text>
      <text class="feedback-score-label">分</text>
    </view>
    <!-- Word-level highlighting -->
    <view class="feedback-words" wx:if="{{wordDisplayData.length > 0}}">
      <view
        wx:for="{{wordDisplayData}}"
        wx:key="index"
        class="feedback-word-wrap"
      >
        <text class="feedback-word feedback-word-{{item.status}}">{{item.word}}</text>
        <text wx:if="{{item.status === 'mispronounced' && item.recognized}}" class="feedback-word-hint">→ {{item.recognized}}</text>
      </view>
    </view>
    <!-- Fallback: missing words tags when no word-level data -->
    <view wx:if="{{wordDisplayData.length === 0 && feedback.missingWords && feedback.missingWords.length > 0}}" class="feedback-missing-row">
      <text class="feedback-missing-label">漏读</text>
      <view class="feedback-missing-tags">
        <text wx:for="{{feedback.missingWords}}" wx:key="*this" class="feedback-missing-tag">{{item}}</text>
      </view>
    </view>
    <view class="feedback-texts">
      <text class="feedback-recognized">你说的：{{feedback.recognizedText}}</text>
      <text class="feedback-original">原句：{{feedback.originalText}}</text>
    </view>
  </view>

  <!-- Controls -->
  <view class="controls" wx:if="{{status !== 'finished'}}">
    <view class="ctrl-btn" bindtap="onSpeedChange">
      <text class="speed-label">{{speed}}x</text>
    </view>
    <view class="ctrl-btn" bindtap="onSkipPrev">
      <text class="ctrl-text">上一句</text>
    </view>
    <view class="ctrl-btn ctrl-btn-primary" bindtap="onTogglePlay">
      <text class="play-text">{{playing ? '暂停' : '播放'}}</text>
    </view>
    <view class="ctrl-btn" bindtap="onSkipNext">
      <text class="ctrl-text">下一句</text>
    </view>
    <view class="ctrl-btn {{loop ? 'active' : ''}}" bindtap="onLoop">
      <text class="ctrl-text">{{loop ? '循环' : '单次'}}</text>
    </view>
  </view>
</view>
