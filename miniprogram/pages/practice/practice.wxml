<view class="container">
  <!-- Mode selection modal -->
  <view class="modal-mask" wx:if="{{showModeModal}}">
    <view class="modal-box">
      <text class="modal-title">选择你的跟读方式</text>
      <text class="modal-subtitle">可在「我的」→「设置」中修改</text>
      <view class="modal-options">
        <view
          wx:for="{{modeModes}}"
          wx:key="key"
          class="modal-option"
          data-mode="{{item.key}}"
          bindtap="onSelectMode"
          hover-class="modal-option-tap"
        >
          <view class="modal-option-left">
            <text class="modal-option-icon">{{item.icon}}</text>
            <view class="modal-option-info">
              <text class="modal-option-name">{{item.name}}</text>
              <text class="modal-option-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Finished overlay -->
  <view wx:if="{{status === 'finished' && finishedData}}" class="finished-wrap">
    <text class="finished-emoji">🎉</text>
    <text class="finished-title">练习完成</text>
    <text class="finished-material">{{finishedData.title}}</text>
    <view class="finished-stats">
      <text class="finished-stat-main">{{finishedData.total}} 句  ·  {{finishedData.durationText}}</text>
      <text wx:if="{{finishedData.showScore}}" class="finished-stat-score">平均 {{finishedData.avgScore}} 分</text>
    </view>
    <view class="finished-buttons">
      <view class="btn-restart" bindtap="onTapRestart" hover-class="btn-tap">重新练</view>
      <view class="btn-back" bindtap="onTapBack" hover-class="btn-tap">返回</view>
    </view>
  </view>

  <!-- Top bar: title + progress -->
  <view class="top-bar" wx:if="{{status !== 'finished'}}">
    <text class="title-text">{{material.title}}</text>
    <text class="progress-label">{{currentIndex + 1}} / {{sentences.length}}</text>
  </view>

  <!-- Subtitles -->
  <view class="subtitle-wrapper" wx:if="{{status !== 'finished'}}">
    <scroll-view class="subtitle-area" scroll-y scroll-into-view="s-{{currentIndex}}" scroll-with-animation bindtap="onTapSubtitleBg">
      <view
        wx:for="{{sentences}}"
        wx:key="id"
        id="s-{{index}}"
        class="subtitle-item {{index === currentIndex ? 'active' : ''}}"
        data-index="{{index}}"
        catchtap="onTapSentence"
      >
        <text class="subtitle-text">{{item.text}}</text>
        <text class="subtitle-translation" wx:if="{{index === currentIndex && item.translation}}">{{item.translation}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- Wait indicator -->
  <view class="status-area" wx:if="{{status !== 'finished'}}">
    <view wx:if="{{status === 'waiting' || recording}}" class="waiting-container">
      <view class="wait-dots" wx:if="{{!recording}}">
        <view class="wait-dot"></view>
        <view class="wait-dot"></view>
        <view class="wait-dot"></view>
      </view>
      <text class="recording-label" wx:if="{{recording}}">录音中…</text>
      <view class="recorder-row">
        <view class="rec-btn {{recording ? 'recording' : ''}}" bindtap="onToggleRecord">
          <text class="rec-icon">{{recording ? '🔴' : '🎙'}}</text>
        </view>
        <view class="rec-btn" wx:if="{{recordPath && !recording}}" bindtap="onPlayback">
          <text class="rec-icon playback-icon">🔊</text>
        </view>
        <view class="rec-btn" bindtap="onSkipNext">
          <text class="rec-icon skip-icon">▶▶</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Feedback -->
  <view class="feedback-area" wx:if="{{showFeedback && feedback && status !== 'finished'}}">
    <view class="feedback-row">
      <text class="feedback-score {{feedback.score >= 80 ? 'score-high' : (feedback.score >= 60 ? 'score-mid' : 'score-low')}}">{{feedback.score}}</text>
      <view class="feedback-words" wx:if="{{feedback.missingWords && feedback.missingWords.length > 0}}">
        <text wx:for="{{feedback.missingWords}}" wx:key="*this" class="missing-tag">{{item}}</text>
      </view>
    </view>
    <view class="feedback-texts">
      <text class="feedback-recognized">你说的：{{feedback.recognizedText}}</text>
      <text class="feedback-original">原句：{{feedback.originalText}}</text>
    </view>
  </view>

  <!-- Controls -->
  <view class="controls" wx:if="{{status !== 'finished'}}">
    <view class="ctrl-btn" bindtap="onSpeedChange">
      <text class="speed-label">{{speed}}x</text>
    </view>
    <view class="ctrl-btn" bindtap="onSkipPrev">
      <text class="ctrl-icon">◀</text>
    </view>
    <view class="ctrl-btn play-btn" bindtap="onTogglePlay">
      <text class="ctrl-icon play-icon">{{playing ? '❚❚' : '▶'}}</text>
    </view>
    <view class="ctrl-btn" bindtap="onSkipNext">
      <text class="ctrl-icon">▶</text>
    </view>
    <view class="ctrl-btn {{loop ? 'loop-on' : ''}}" bindtap="onLoop">
      <text class="ctrl-icon">↻</text>
    </view>
  </view>
</view>
