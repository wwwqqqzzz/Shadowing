.container {
  padding: 0 32rpx;
  background: var(--color-bg-base);
  min-height: 100vh;
}

/* Loading */
.loading-area {
  display: flex;
  justify-content: center;
  padding-top: 300rpx;
}

.wait-dots {
  display: flex;
  gap: 16rpx;
}

.wait-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-brand);
  animation: dotPulse 1.2s ease-in-out infinite;
}

.wait-dot:nth-child(2) {
  animation-delay: 0.3s;
}

.wait-dot:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

/* ─── Streak bar ─── */
.streak-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 0 20rpx;
}

.streak-flame {
  font-size: 28rpx;
  color: var(--color-brand);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.streak-start {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 400;
}

.streak-today {
  font-size: 24rpx;
}

.streak-today.done {
  color: var(--color-brand);
}

.streak-today.undone {
  color: var(--color-text-tertiary);
}

/* ─── Hero card ─── */
.hero-card {
  background: var(--color-bg-surface);
  border-radius: var(--radius-xl);
  border-left: 6rpx solid var(--color-brand);
  padding: var(--space-5) var(--space-4);
  margin-bottom: var(--space-4);
}

.hero-card-tap {
  opacity: 0.85;
}

.hero-label {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-brand);
  font-weight: var(--font-weight-semibold);
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 4rpx;
}

.hero-title {
  display: block;
  font-size: var(--font-size-lg);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
  line-height: var(--line-height-tight);
  margin-bottom: var(--space-2);
}

.hero-material {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-3);
}

.hero-sub {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  margin-bottom: var(--space-2);
}

.hero-meta-item {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.hero-meta-sep {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.hero-tags {
  display: flex;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.hero-tag {
  display: inline-block;
  background: var(--color-border-default);
  color: var(--color-text-secondary);
  font-size: var(--font-size-xs);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

.hero-progress-track {
  height: 6rpx;
  background: var(--color-bg-overlay);
  border-radius: var(--radius-full);
  margin-top: var(--space-3);
  overflow: hidden;
}

.hero-progress-fill {
  height: 100%;
  background: var(--color-brand);
  border-radius: var(--radius-full);
  min-width: 12rpx;
  transition: width 0.3s ease;
}

/* ─── Wrong book card ─── */
.wrong-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--color-bg-elevated);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.wrong-card-tap {
  opacity: 0.85;
}

.wrong-left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.wrong-icon {
  display: none;
}

.wrong-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.wrong-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.wrong-arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary);
}

/* ─── Quick section (difficulty level cards) ─── */
.quick-section {
  padding: 8rpx 0 0;
}

.quick-title {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-bottom: var(--space-3);
  letter-spacing: 1rpx;
}

.level-grid {
  display: flex;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.level-card {
  flex: 1;
  background: var(--color-bg-surface);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-subtle);
  padding: var(--space-3) var(--space-2);
  text-align: center;
}

.level-card-tap {
  opacity: 0.85;
}

.level-card-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.level-card.beginner {
  border-left: 4rpx solid var(--color-score-high);
}

.level-card.intermediate {
  border-left: 4rpx solid var(--color-score-mid);
}

.level-card.advanced {
  border-left: 4rpx solid var(--color-score-low);
}

.quick-all {
  display: block;
  text-align: center;
  margin-top: var(--space-2);
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  padding: var(--space-2) 0;
}

/* ─── Recent materials section ─── */

.section {
  margin-top: var(--space-5);
}

.section-title {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-bottom: var(--space-3);
}

.recent-material-item {
  display: flex;
  align-items: center;
  padding: var(--space-3) 0;
  border-bottom: 1rpx solid var(--color-border-subtle);
}

.recent-material-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-brand);
  margin-right: var(--space-3);
  flex-shrink: 0;
}

.recent-material-title {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-material-meta {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
  margin-left: var(--space-2);
}