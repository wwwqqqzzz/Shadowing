.container {
  padding: 0 32rpx;
  background: #0f0f0f;
  min-height: 100vh;
}

/* Loading */
.loading-area {
  display: flex;
  justify-content: center;
  padding-top: 300rpx;
}

.wait-dots {
  display: flex;
  gap: 16rpx;
}

.wait-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #a8e6cf;
  animation: dotPulse 1.2s ease-in-out infinite;
}

.wait-dot:nth-child(2) {
  animation-delay: 0.3s;
}

.wait-dot:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

/* Streak bar */
.streak-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0 24rpx;
}

.streak-flame {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.streak-start {
  font-size: 30rpx;
  color: #888;
  font-weight: 400;
}

.streak-today {
  font-size: 24rpx;
}

.streak-today.done {
  color: #a8e6cf;
}

.streak-today.undone {
  color: #e8a87c;
}

/* Hero card */
.hero-card {
  background: linear-gradient(145deg, #1a2a1a 0%, #0f0f0f 100%);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #2a2a2a;
}

.hero-card-tap {
  opacity: 0.85;
}

.hero-title {
  display: block;
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.hero-material {
  display: block;
  font-size: 28rpx;
  color: #aaa;
  margin-bottom: 24rpx;
}

.hero-sub {
  display: block;
  font-size: 26rpx;
  color: #777;
  margin-bottom: 20rpx;
}

.hero-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.hero-tag {
  display: inline-block;
  background: #2a2a2a;
  color: #aaa;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 99rpx;
}

.hero-progress-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hero-progress-text {
  font-size: 24rpx;
  color: #888;
}

.hero-progress-bar {
  flex: 1;
  margin-left: 20rpx;
  height: 8rpx;
  background: #2a2a2a;
  border-radius: 4rpx;
  overflow: hidden;
}

.hero-progress-fill {
  height: 100%;
  background: #a8e6cf;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.hero-cta {
  display: flex;
  justify-content: flex-end;
}

.hero-cta-text {
  font-size: 30rpx;
  color: #a8e6cf;
  font-weight: 600;
}

/* Wrong book card */
.wrong-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #1a1a1a;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.wrong-card-tap {
  opacity: 0.85;
}

.wrong-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.wrong-icon {
  font-size: 32rpx;
}

.wrong-label {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.wrong-count {
  font-size: 24rpx;
  color: #888;
}

.wrong-arrow {
  font-size: 36rpx;
  color: #666;
}

/* Quick filters */
.quick-section {
  padding: 16rpx 0;
}

.quick-title {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.quick-row {
  display: flex;
  gap: 16rpx;
}

.quick-tag {
  background: #2a2a2a;
  color: #ccc;
  font-size: 26rpx;
  padding: 14rpx 32rpx;
  border-radius: 99rpx;
  text-align: center;
}

.quick-tag-mid {
  background: rgba(168, 230, 207, 0.12);
  color: #a8e6cf;
}

.quick-tag-adv {
  background: rgba(255, 153, 153, 0.12);
  color: #ff9999;
}

.quick-all {
  display: block;
  text-align: center;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #a8e6cf;
  padding: 16rpx 0;
}
