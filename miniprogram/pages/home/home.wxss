.container {
  padding: 0 32rpx;
  background: var(--color-bg-base);
  min-height: 100vh;
}

/* Loading */
.loading-area {
  display: flex;
  justify-content: center;
  padding-top: 300rpx;
}

.wait-dots {
  display: flex;
  gap: 16rpx;
}

.wait-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-brand);
  animation: dotPulse 1.2s ease-in-out infinite;
}

.wait-dot:nth-child(2) {
  animation-delay: 0.3s;
}

.wait-dot:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

/* Streak bar */
.streak-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0 24rpx;
}

.streak-flame {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.streak-start {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 400;
}

.streak-today {
  font-size: 24rpx;
}

.streak-today.done {
  color: var(--color-brand);
}

.streak-today.undone {
  color: var(--color-warning);
}

/* Hero card */
.hero-card {
  background: linear-gradient(145deg, var(--color-brand-dim) 0%, var(--color-bg-base) 100%);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--color-border-default);
}

.hero-card-tap {
  opacity: 0.85;
}

.hero-title {
  display: block;
  font-size: 36rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.hero-material {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.hero-sub {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.hero-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.hero-tag {
  display: inline-block;
  background: var(--color-border-default);
  color: var(--color-text-secondary);
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 99rpx;
}

.hero-progress-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hero-progress-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.hero-progress-bar {
  flex: 1;
  margin-left: 20rpx;
  height: 8rpx;
  background: var(--color-border-default);
  border-radius: 4rpx;
  overflow: hidden;
}

.hero-progress-fill {
  height: 100%;
  background: var(--color-brand);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.hero-cta {
  display: flex;
  justify-content: flex-end;
}

.hero-cta-text {
  font-size: 30rpx;
  color: var(--color-brand);
  font-weight: 600;
}

/* Wrong book card */
.wrong-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--color-bg-elevated);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.wrong-card-tap {
  opacity: 0.85;
}

.wrong-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.wrong-icon {
  font-size: 32rpx;
}

.wrong-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.wrong-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.wrong-arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary);
}

/* Quick filters */
.quick-section {
  padding: 16rpx 0;
}

.quick-title {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.quick-row {
  display: flex;
  gap: 16rpx;
}

.quick-tag {
  background: var(--color-border-default);
  color: var(--color-text-primary);
  font-size: 26rpx;
  padding: 14rpx 32rpx;
  border-radius: 99rpx;
  text-align: center;
}

.quick-tag-mid {
  background: rgba(125, 206, 160, 0.12);
  color: var(--color-brand);
}

.quick-tag-adv {
  background: rgba(192, 97, 107, 0.12);
  color: var(--color-score-low);
}

.quick-all {
  display: block;
  text-align: center;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--color-brand);
  padding: 16rpx 0;
}
