.container {
  padding: 0 32rpx;
  background: var(--color-bg-base);
  min-height: 100vh;
}

/* Loading */
.loading-area {
  display: flex;
  justify-content: center;
  padding-top: 300rpx;
}

.wait-dots {
  display: flex;
  gap: 16rpx;
}

.wait-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-brand);
  animation: dotPulse 1.2s ease-in-out infinite;
}

.wait-dot:nth-child(2) {
  animation-delay: 0.3s;
}

.wait-dot:nth-child(3) {
  animation-delay: 0.6s;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1); }
}

/* ─── Streak bar ─── */
.streak-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 0 20rpx;
}

.streak-flame {
  font-size: 28rpx;
  color: var(--color-brand);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.streak-start {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 400;
}

.streak-today {
  font-size: 24rpx;
}

.streak-today.done {
  color: var(--color-brand);
}

.streak-today.undone {
  color: var(--color-text-tertiary);
}

/* ─── Hero card ─── */
.hero-card {
  background: var(--color-bg-elevated);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid var(--color-brand);
}

.hero-card-tap {
  opacity: 0.85;
}

.hero-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-brand);
  font-weight: 600;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.hero-title {
  display: block;
  font-size: 34rpx;
  color: var(--color-text-primary);
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 12rpx;
}

.hero-material {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.hero-sub {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.hero-meta-item {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.hero-meta-sep {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.hero-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.hero-tag {
  display: inline-block;
  background: var(--color-border-default);
  color: var(--color-text-secondary);
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 99rpx;
}

.hero-progress-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hero-progress-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.hero-progress-bar {
  flex: 1;
  margin-left: 20rpx;
  height: 8rpx;
  background: var(--color-border-default);
  border-radius: 4rpx;
  overflow: hidden;
}

.hero-progress-fill {
  height: 100%;
  background: var(--color-brand);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.hero-cta {
  display: flex;
  justify-content: flex-end;
}

.hero-cta-text {
  font-size: 30rpx;
  color: var(--color-brand);
  font-weight: 600;
}

/* ─── Wrong book card ─── */
.wrong-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--color-bg-elevated);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}

.wrong-card-tap {
  opacity: 0.85;
}

.wrong-left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.wrong-icon {
  display: none;
}

.wrong-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.wrong-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.wrong-arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary);
}

/* ─── Quick section (difficulty cards) ─── */
.quick-section {
  padding: 8rpx 0 0;
}

.quick-title {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.quick-grid {
  display: flex;
  gap: 16rpx;
}

.quick-card {
  flex: 1;
  background: var(--color-bg-elevated);
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.quick-card-tap {
  opacity: 0.85;
}

.quick-card-level {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.quick-card-hint {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.quick-all {
  display: block;
  text-align: center;
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  padding: 16rpx 0;
}