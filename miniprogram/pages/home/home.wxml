<view class="container">
  <view class="loading-area" wx:if="{{loading}}">
    <view class="wait-dots">
      <view class="wait-dot"></view>
      <view class="wait-dot"></view>
      <view class="wait-dot"></view>
    </view>
  </view>

  <block wx:else>
    <!-- 区域一：打卡状态栏 -->
    <view class="streak-bar">
      <block wx:if="{{currentStreak > 0}}">
        <text class="streak-flame">{{currentStreak}} 天连续</text>
        <text class="streak-today {{todayDone ? 'done' : 'undone'}}">
          {{todayDone ? '今天已打卡' : '今天还没练'}}
        </text>
      </block>
      <block wx:else>
        <text class="streak-start">开始你的第一次练习</text>
      </block>
    </view>

    <!-- 区域二：主 Hero -->
    <view class="hero-card" bindtap="onTapHero" hover-class="hero-card-tap">

      <!-- continue 状态 -->
      <block wx:if="{{heroState === 'continue'}}">
        <text class="hero-label">继续</text>
        <text class="hero-title">{{lastProgress.material.title}}</text>
        <view class="hero-meta">
          <text class="hero-meta-item">{{lastProgress.totalSentences}} 句</text>
          <text class="hero-meta-sep">·</text>
          <text class="hero-meta-item">{{lastProgress.lastSentenceOrder}} / {{lastProgress.totalSentences}}</text>
        </view>
        <view class="hero-progress-track">
          <view class="hero-progress-fill" style="width: {{lastProgress.progressPercent}}%"></view>
        </view>
      </block>

      <!-- replay 状态 -->
      <block wx:elif="{{heroState === 'replay'}}">
        <text class="hero-label">已完成</text>
        <text class="hero-title">{{lastProgress.material.title}}</text>
        <view class="hero-meta">
          <text class="hero-meta-item">{{lastProgress.totalSentences}} 句</text>
          <text class="hero-meta-sep">·</text>
          <text class="hero-meta-item">从头开始</text>
        </view>
      </block>

      <!-- start 状态 -->
      <block wx:else>
        <text class="hero-label">开始</text>
        <text class="hero-title">选择一个素材</text>
        <text class="hero-sub">从跟读开始提升英语</text>
      </block>
    </view>

    <!-- 区域三：错题提醒 -->
    <view class="wrong-card" wx:if="{{wrongCount > 0}}" bindtap="onTapWrongBook" hover-class="wrong-card-tap">
      <view class="wrong-left">
        <text class="wrong-label">错题本</text>
        <text class="wrong-count">{{wrongCount}} 句</text>
      </view>
      <text class="wrong-arrow">›</text>
    </view>

    <!-- 区域四：难度快速入口 -->
    <view class="quick-section">
      <text class="quick-title">按难度浏览</text>
      <view class="level-grid">
        <view class="level-card beginner" data-level="beginner" bindtap="onTapLevelFilter" hover-class="level-card-tap">
          <text class="level-card-title">初级</text>
        </view>
        <view class="level-card intermediate" data-level="intermediate" bindtap="onTapLevelFilter" hover-class="level-card-tap">
          <text class="level-card-title">中级</text>
        </view>
        <view class="level-card advanced" data-level="advanced" bindtap="onTapLevelFilter" hover-class="level-card-tap">
          <text class="level-card-title">高级</text>
        </view>
      </view>
      <view class="quick-all" bindtap="onTapAllMaterials">查看全部素材 ›</view>
    </view>

    <!-- 区域五：最近加入 -->
    <view wx:if="{{recentMaterials.length > 0}}" class="section">
      <text class="section-title">最近加入</text>
      <view
        wx:for="{{recentMaterials}}"
        wx:key="id"
        class="recent-material-item"
        data-id="{{item.id}}"
        data-title="{{item.title}}"
        bindtap="onTapRecentMaterial"
        hover-class="level-card-tap"
      >
        <view class="recent-material-dot"></view>
        <text class="recent-material-title">{{item.title}}</text>
        <text class="recent-material-meta">{{item.source}}</text>
      </view>
    </view>
  </block>
</view>