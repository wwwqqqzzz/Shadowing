<view class="container">
  <view class="loading-area" wx:if="{{loading}}">
    <view class="wait-dots">
      <view class="wait-dot"></view>
      <view class="wait-dot"></view>
      <view class="wait-dot"></view>
    </view>
  </view>

  <block wx:else>
    <!-- 区域一：打卡状态栏 -->
    <view class="streak-bar">
      <block wx:if="{{currentStreak > 0}}">
        <text class="streak-flame">🔥 {{currentStreak}}天连续练习</text>
        <text class="streak-today {{todayDone ? 'done' : 'undone'}}">
          {{todayDone ? '今天已打卡 ✓' : '今天还没练'}}
        </text>
      </block>
      <block wx:else>
        <text class="streak-start">开始你的第一次练习</text>
      </block>
    </view>

    <!-- 区域二：主 Hero 按钮 -->
    <view class="hero-card" bindtap="onTapHero" hover-class="hero-card-tap">

      <!-- continue 状态 -->
      <block wx:if="{{heroState === 'continue'}}">
        <text class="hero-title">继续上次练习</text>
        <text class="hero-material">{{lastProgress.material.title}}</text>
        <view class="hero-progress-row">
          <text class="hero-progress-text">第 {{lastProgress.lastSentenceOrder}} 句 / 共 {{lastProgress.totalSentences}} 句</text>
          <view class="hero-progress-bar">
            <view class="hero-progress-fill" style="width: {{lastProgress.progressPercent}}%"></view>
          </view>
        </view>
        <view class="hero-cta">
          <text class="hero-cta-text">▶ 继续</text>
        </view>
      </block>

      <!-- recommend 状态 -->
      <block wx:elif="{{heroState === 'recommend'}}">
        <text class="hero-title">今日推荐</text>
        <text class="hero-material">{{lastProgress.material.title}}</text>
        <view class="hero-tags">
          <text class="hero-tag">{{lastProgress.material.level === 'beginner' ? '入门' : lastProgress.material.level === 'intermediate' ? '中级' : '高级'}}</text>
          <text class="hero-tag">{{lastProgress.material.accent === 'american' ? '美式' : lastProgress.material.accent === 'british' ? '英式' : lastProgress.material.accent === 'australian' ? '澳式' : lastProgress.material.accent}}</text>
        </view>
        <view class="hero-cta">
          <text class="hero-cta-text">▶ 开始练</text>
        </view>
      </block>

      <!-- start 状态 -->
      <block wx:else>
        <text class="hero-title">开始你的第一次练习</text>
        <text class="hero-sub">从这里出发</text>
        <view class="hero-cta">
          <text class="hero-cta-text">▶ 去选择</text>
        </view>
      </block>
    </view>

    <!-- 区域三：错题提醒 -->
    <view class="wrong-card" wx:if="{{wrongCount > 0}}" bindtap="onTapWrongBook" hover-class="wrong-card-tap">
      <view class="wrong-left">
        <text class="wrong-icon">📚</text>
        <text class="wrong-label">错题本</text>
        <text class="wrong-count">{{wrongCount}} 句待复习</text>
      </view>
      <text class="wrong-arrow">›</text>
    </view>

    <!-- 区域四：快捷入口 -->
    <view class="quick-section">
      <text class="quick-title">难度快速筛选</text>
      <view class="quick-row">
        <view class="quick-tag" data-level="beginner" bindtap="onTapLevelFilter">初级</view>
        <view class="quick-tag quick-tag-mid" data-level="intermediate" bindtap="onTapLevelFilter">中级</view>
        <view class="quick-tag quick-tag-adv" data-level="advanced" bindtap="onTapLevelFilter">高级</view>
      </view>
      <view class="quick-all" bindtap="onTapAllMaterials">查看全部素材 ›</view>
    </view>
  </block>
</view>