<view class="container">
  <view class="section-title">跟读模式</view>

  <view class="mode-list">
    <view
      wx:for="{{modes}}"
      wx:key="key"
      class="mode-card {{item.key === currentMode ? 'active' : ''}}"
      data-mode="{{item.key}}"
      bindtap="onSelectMode"
      hover-class="mode-card-tap"
    >
      <view class="mode-left">
        <text class="mode-icon">{{item.icon}}</text>
        <view class="mode-info">
          <text class="mode-name">{{item.key === 'free' ? '自由模式' : (item.key === 'auto' ? '自动录音' : '手动模式')}}</text>
          <text class="mode-desc">{{item.desc}}</text>
        </view>
      </view>
      <text class="mode-check" wx:if="{{item.key === currentMode}}">✓</text>
    </view>
  </view>

  <view class="section-title">播放设置</view>

  <view class="setting-row">
    <view class="setting-left">
      <text class="setting-label">跟读等待时长</text>
      <text class="setting-hint">自由模式播完后等待时间</text>
    </view>
    <picker
      mode="selector"
      range="{{waitOptions}}"
      range-key="label"
      value="{{waitIndex}}"
      bindchange="onChangeWait"
    >
      <text class="setting-value">{{waitLabel}} ›</text>
    </picker>
  </view>
</view>