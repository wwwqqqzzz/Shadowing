page {
  background: var(--color-bg-base);
}

.container {
  min-height: 100vh;
  background: var(--color-bg-base);
}

.section-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  padding: 32rpx 32rpx 20rpx;
}

.mode-list {
  padding: 0 32rpx;
}

.mode-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-elevated);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s ease;
}

.mode-card.active {
  border-color: var(--color-brand);
}

.mode-card-tap {
  opacity: 0.7;
}

.mode-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
  min-width: 0;
}

.mode-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.mode-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.mode-name {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.mode-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.mode-check {
  font-size: 32rpx;
  color: var(--color-brand);
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ─── Setting row ─────────────────────────────────────── */

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-elevated);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin: 0 32rpx 20rpx;
}

.setting-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.setting-label {
  font-size: 30rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.setting-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.setting-value {
  font-size: 28rpx;
  color: var(--color-brand);
}