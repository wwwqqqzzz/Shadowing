page { background: #0f0f0f; }
.container { padding: 32rpx; min-height: 100vh; }

/* ─── Progress ─────────────────────────────────────────── */

.progress {
  color: #888;
  font-size: 26rpx;
  margin-bottom: 32rpx;
}

/* ─── Sentence card ────────────────────────────────────── */

.sentence-card {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.sentence-text {
  display: block;
  color: #fff;
  font-size: 32rpx;
  line-height: 1.6;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.sentence-translation {
  display: block;
  color: #888;
  font-size: 26rpx;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.sentence-material {
  display: block;
  color: #555;
  font-size: 22rpx;
  margin-top: 8rpx;
}

/* ─── Controls ─────────────────────────────────────────── */

.controls {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.play-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #a8e6cf;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #0f0f0f;
}

.play-btn.playing {
  background: #e8a87c;
}

/* ─── Recording ─────────────────────────────────────────── */

.recording-area {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx 0;
}

.rec-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e86666;
  animation: recPulse 1s ease-in-out infinite;
}

@keyframes recPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.8); }
}

.rec-time {
  color: #e86666;
  font-size: 28rpx;
  font-weight: 600;
}

/* ─── Feedback ──────────────────────────────────────────── */

.feedback {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 32rpx;
}

.score {
  font-size: 72rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 24rpx;
}

.score-low { color: #e86666; }
.score-mid { color: #e8a87c; }
.score-ok { color: #a8e6cf; }

.one-move {
  display: block;
  text-align: center;
  color: #a8e6cf;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.missing-words {
  margin-bottom: 24rpx;
}

.missing-label {
  display: block;
  color: #e8a87c;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.word-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.word-tag {
  background: #252525;
  color: #e86666;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.text-compare {
  margin-bottom: 32rpx;
}

.compare-row {
  margin-bottom: 16rpx;
}

.compare-label {
  display: block;
  color: #666;
  font-size: 22rpx;
  margin-bottom: 4rpx;
}

.compare-text {
  display: block;
  color: #ddd;
  font-size: 26rpx;
  line-height: 1.5;
}

.feedback-actions {
  display: flex;
  gap: 24rpx;
}

.retry-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 24rpx;
  background: #252525;
  color: #888;
  font-size: 28rpx;
  font-weight: 500;
}

.next-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 24rpx;
  background: #a8e6cf;
  color: #0f0f0f;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-tap { opacity: 0.8; }

/* ─── Finished ──────────────────────────────────────────── */

.finished {
  padding-top: 100rpx;
  text-align: center;
}

.finished-emoji {
  display: block;
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.finished-title {
  display: block;
  color: #a8e6cf;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 48rpx;
}

.summary-cards {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.summary-card {
  flex: 1;
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.summary-num {
  font-size: 52rpx;
  font-weight: 700;
  color: #ddd;
}

.summary-num.ok { color: #a8e6cf; }
.summary-num.mid { color: #e8a87c; }
.summary-num.low { color: #e86666; }

.summary-label {
  font-size: 22rpx;
  color: #666;
}

.finished-change {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 20rpx 32rpx;
  margin-bottom: 32rpx;
}

.change-detail {
  color: #a8e6cf;
  font-size: 26rpx;
  font-weight: 500;
}

.finished-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.finished-actions .retry-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 24rpx;
  background: #252525;
  color: #888;
  font-size: 28rpx;
}

.finished-actions .back-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 24rpx;
  background: #a8e6cf;
  color: #0f0f0f;
  font-size: 28rpx;
  font-weight: 600;
}